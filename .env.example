# Base de datos Postgres (Drizzle + pg)
DATABASE_URL=postgres://user:password@host:5432/dbname
# Tamaño máximo del pool de conexiones (opcional, default 5)
# PG_POOL_MAX=5

# better-auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=genera-un-secreto-largo-y-aleatorio

# zoho-hub (solo lectura). Si se define, las ventas se leen EN VIVO del hub en vez
# de sales_records. Usuario read-only hub_reader. Host interno EasyPanel.
# HUB_DB_URL=postgres://hub_reader:<PASSWORD>@ambientalia_project_zoho-hub-db:5432/zoho-hub
# HUB_POOL_MAX=5

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
